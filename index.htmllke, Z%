<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>Les Corvées — Négation NL</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --orange: #FF6B35;
  --orange-light: #FFF0EB;
  --orange-dark: #CC4E1A;
  --blue: #2D6BE4;
  --blue-light: #EBF1FD;
  --green: #1DB87A;
  --green-light: #E6F9F1;
  --red: #E84040;
  --red-light: #FDEAEA;
  --bg: #F5F4F0;
  --white: #FFFFFF;
  --text: #1A1A2E;
  --text-muted: #7B7B8F;
  --border: #E8E7E3;
  --shadow: 0 2px 12px rgba(0,0,0,0.08);
  --shadow-lg: 0 8px 32px rgba(0,0,0,0.12);
  --radius: 16px;
  --radius-sm: 10px;
  --radius-pill: 50px;
}
* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
html, body { height: 100%; background: var(--bg); font-family: 'Nunito', sans-serif; color: var(--text); overflow-x: hidden; }
body { min-height: 100dvh; }

/* ---- HEADER ---- */
.app-header {
  background: var(--white);
  padding: 14px 20px 12px;
  display: flex; align-items: center; gap: 12px;
  border-bottom: 1px solid var(--border);
  position: sticky; top: 0; z-index: 10;
  box-shadow: 0 1px 8px rgba(0,0,0,0.06);
}
.app-logo {
  width: 36px; height: 36px; border-radius: 10px;
  background: var(--orange); display: flex; align-items: center; justify-content: center;
  font-size: 18px; flex-shrink: 0;
}
.app-header-text { flex: 1; }
.app-header-title { font-size: 15px; font-weight: 800; color: var(--text); line-height: 1.2; }
.app-header-sub { font-size: 12px; color: var(--text-muted); font-weight: 600; }
.score-chip {
  background: var(--orange-light); color: var(--orange-dark);
  border-radius: var(--radius-pill); padding: 6px 14px;
  font-size: 13px; font-weight: 800; flex-shrink: 0;
  display: none;
}
.score-chip.show { display: block; }

/* ---- PROGRESS ---- */
.progress-wrap { padding: 0 20px; margin-top: 4px; display: none; }
.progress-wrap.show { display: block; }
.progress-track { height: 6px; background: var(--border); border-radius: 3px; margin: 10px 0 0; }
.progress-fill { height: 6px; background: linear-gradient(90deg, var(--orange), #FF9F6A); border-radius: 3px; transition: width .4s cubic-bezier(.4,0,.2,1); }
.progress-label { display: flex; justify-content: space-between; font-size: 11px; color: var(--text-muted); font-weight: 600; margin-top: 4px; padding-bottom: 8px; }

/* ---- SCROLL CONTAINER ---- */
.scroll-body { padding: 20px 20px 100px; }

/* ---- VIEWS ---- */
.view { display: none; }
.view.active { display: block; }

/* ---- MENU ---- */
.menu-hero {
  background: var(--white); border-radius: var(--radius); padding: 28px 20px 20px;
  margin-bottom: 16px; text-align: center; box-shadow: var(--shadow);
}
.menu-emoji { font-size: 48px; margin-bottom: 10px; }
.menu-title { font-size: 22px; font-weight: 800; color: var(--text); margin-bottom: 6px; }
.menu-desc { font-size: 14px; color: var(--text-muted); font-weight: 600; line-height: 1.5; }

.section-label { font-size: 12px; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: .08em; margin-bottom: 10px; }

.level-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 20px; }
.level-card {
  background: var(--white); border-radius: var(--radius); padding: 18px 14px;
  border: 2px solid transparent; cursor: pointer;
  transition: all .2s; box-shadow: var(--shadow);
  position: relative; overflow: hidden;
}
.level-card.selected { border-color: var(--orange); background: var(--orange-light); }
.level-card.locked { opacity: .5; cursor: not-allowed; }
.level-card-icon { font-size: 26px; margin-bottom: 8px; }
.level-card-name { font-size: 15px; font-weight: 800; color: var(--text); margin-bottom: 4px; }
.level-card-desc { font-size: 12px; color: var(--text-muted); font-weight: 600; line-height: 1.4; }
.lock-overlay {
  position: absolute; top: 8px; right: 10px;
  font-size: 16px; opacity: .6;
}
.badge-unlocked {
  background: var(--green-light); color: #0E7A50;
  border-radius: var(--radius-pill); padding: 6px 14px;
  font-size: 12px; font-weight: 800; text-align: center;
  margin-bottom: 14px; display: none;
}
.badge-unlocked.show { display: block; }
.lock-msg {
  background: var(--red-light); color: var(--red);
  border-radius: var(--radius-sm); padding: 10px 14px;
  font-size: 13px; font-weight: 700; margin-bottom: 14px; display: none;
  text-align: center;
}
.lock-msg.show { display: block; }

.btn-start {
  width: 100%; padding: 18px;
  background: var(--orange); color: white;
  border: none; border-radius: var(--radius); font-size: 17px; font-weight: 800;
  cursor: pointer; font-family: 'Nunito', sans-serif;
  box-shadow: 0 4px 16px rgba(255,107,53,.35);
  transition: all .15s; letter-spacing: .02em;
  active: transform: scale(.98);
}
.btn-start:active { transform: scale(.97); box-shadow: 0 2px 8px rgba(255,107,53,.3); }

/* ---- QUESTION CARD ---- */
.q-card {
  background: var(--white); border-radius: var(--radius);
  padding: 20px; margin-bottom: 14px;
  box-shadow: var(--shadow);
}
.q-mode-badge {
  display: inline-block; background: var(--bg); color: var(--text-muted);
  border-radius: var(--radius-pill); padding: 4px 12px;
  font-size: 11px; font-weight: 800; text-transform: uppercase;
  letter-spacing: .06em; margin-bottom: 12px;
}
.q-sentence {
  font-size: 19px; font-weight: 700; color: var(--text); line-height: 1.5;
  margin-bottom: 8px;
}
.blank {
  display: inline-block; min-width: 70px;
  border-bottom: 3px solid var(--orange);
  color: var(--orange); padding: 0 4px; text-align: center;
}
.q-hint {
  font-size: 13px; color: var(--text-muted); font-weight: 600;
  font-style: italic; margin-bottom: 4px;
}
.q-fr {
  font-size: 13px; color: var(--blue); font-weight: 700;
  background: var(--blue-light); border-radius: var(--radius-sm);
  padding: 8px 12px; margin-top: 8px;
}

/* ---- QCM ---- */
.choices { display: flex; flex-direction: column; gap: 10px; margin-bottom: 14px; }
.choice-btn {
  width: 100%; padding: 16px 18px; text-align: left;
  background: var(--white); border: 2px solid var(--border);
  border-radius: var(--radius); font-size: 16px; font-weight: 700;
  color: var(--text); cursor: pointer; font-family: 'Nunito', sans-serif;
  transition: all .15s; display: flex; align-items: center; gap: 12px;
  box-shadow: var(--shadow);
}
.choice-btn:active { transform: scale(.98); }
.choice-btn .choice-letter {
  width: 32px; height: 32px; border-radius: 50%;
  background: var(--bg); display: flex; align-items: center; justify-content: center;
  font-size: 13px; font-weight: 800; color: var(--text-muted); flex-shrink: 0;
}
.choice-btn.correct { background: var(--green-light); border-color: var(--green); color: #0E7A50; }
.choice-btn.correct .choice-letter { background: var(--green); color: white; }
.choice-btn.wrong { background: var(--red-light); border-color: var(--red); color: var(--red); }
.choice-btn.wrong .choice-letter { background: var(--red); color: white; }
.choice-btn.missed { background: var(--green-light); border-color: var(--green); opacity: .6; color: #0E7A50; }
.choice-btn:disabled { cursor: default; transform: none; }

/* ---- BUILD ---- */
.build-zone { margin-bottom: 14px; }
.zone-label { font-size: 12px; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: .06em; margin-bottom: 8px; }
.built-area {
  min-height: 58px; background: var(--white); border: 2px dashed var(--border);
  border-radius: var(--radius); padding: 10px 12px;
  font-size: 16px; font-weight: 700; color: var(--text);
  line-height: 2; margin-bottom: 12px; box-shadow: inset 0 1px 4px rgba(0,0,0,.04);
}
.wchip {
  display: inline-flex; align-items: center;
  background: var(--orange-light); border: 1.5px solid #FFBB99;
  border-radius: var(--radius-sm); padding: 4px 12px; margin: 3px 4px;
  cursor: pointer; font-size: 14px; font-weight: 700; color: var(--orange-dark);
  transition: background .1s;
}
.wchip:active { background: var(--red-light); }
.word-bank { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
.wb-btn {
  background: var(--white); border: 2px solid var(--border);
  border-radius: var(--radius-sm); padding: 10px 16px;
  font-size: 15px; font-weight: 700; color: var(--text);
  cursor: pointer; font-family: 'Nunito', sans-serif;
  transition: all .15s; box-shadow: var(--shadow);
}
.wb-btn:active { transform: scale(.95); }
.wb-btn.used { opacity: .25; pointer-events: none; }
.build-controls { display: flex; gap: 10px; margin-bottom: 0; }
.btn-clear {
  flex: 1; padding: 14px; background: var(--bg); border: 2px solid var(--border);
  border-radius: var(--radius); font-size: 14px; font-weight: 800;
  color: var(--text-muted); cursor: pointer; font-family: 'Nunito', sans-serif;
}
.btn-verify {
  flex: 2; padding: 14px; background: var(--blue); border: none;
  border-radius: var(--radius); font-size: 15px; font-weight: 800;
  color: white; cursor: pointer; font-family: 'Nunito', sans-serif;
  box-shadow: 0 4px 12px rgba(45,107,228,.3);
}
.btn-verify:active { transform: scale(.97); }

/* ---- WRITE ---- */
.write-zone { margin-bottom: 14px; }
.write-textarea {
  width: 100%; min-height: 70px; padding: 14px 16px;
  background: var(--white); border: 2px solid var(--border);
  border-radius: var(--radius); font-size: 16px; font-weight: 700;
  color: var(--text); font-family: 'Nunito', sans-serif;
  resize: none; outline: none; box-shadow: var(--shadow);
  transition: border-color .2s;
}
.write-textarea:focus { border-color: var(--blue); }
.write-textarea.ok { border-color: var(--green); background: var(--green-light); color: #0E7A50; }
.write-textarea.ko { border-color: var(--red); background: var(--red-light); color: var(--red); }

/* ---- FEEDBACK ---- */
.feedback {
  border-radius: var(--radius); padding: 14px 16px;
  font-size: 14px; font-weight: 700; line-height: 1.6;
  margin-bottom: 14px; display: none;
}
.feedback.show { display: block; }
.feedback.ok { background: var(--green-light); color: #0E7A50; border: 1.5px solid #7ADDB6; }
.feedback.ko { background: var(--red-light); color: #C02020; border: 1.5px solid #F5AAAA; }
.feedback .fb-icon { font-size: 20px; margin-bottom: 4px; }
.feedback strong { font-weight: 800; }

/* ---- NEXT BTN (sticky) ---- */
.sticky-next {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 12px 20px 28px; background: var(--bg);
  border-top: 1px solid var(--border);
  display: none;
}
.sticky-next.show { display: block; }
.btn-next {
  width: 100%; padding: 18px; background: var(--orange); color: white;
  border: none; border-radius: var(--radius); font-size: 17px; font-weight: 800;
  cursor: pointer; font-family: 'Nunito', sans-serif;
  box-shadow: 0 4px 16px rgba(255,107,53,.35);
  letter-spacing: .02em;
}
.btn-next:active { transform: scale(.98); }

/* ---- END ---- */
.end-card {
  background: var(--white); border-radius: var(--radius);
  padding: 32px 20px; text-align: center;
  box-shadow: var(--shadow); margin-bottom: 16px;
}
.end-trophy { font-size: 56px; margin-bottom: 8px; }
.end-title { font-size: 22px; font-weight: 800; margin-bottom: 6px; }
.end-score { font-size: 52px; font-weight: 800; color: var(--orange); margin: 10px 0; }
.end-msg { font-size: 15px; color: var(--text-muted); font-weight: 600; line-height: 1.5; margin-bottom: 16px; }
.end-unlock-msg {
  background: var(--green-light); color: #0E7A50;
  border-radius: var(--radius-sm); padding: 12px 16px;
  font-size: 14px; font-weight: 700; margin-bottom: 0;
  display: none;
}
.end-unlock-msg.show { display: block; }
.end-btns { display: flex; flex-direction: column; gap: 10px; }
.btn-menu { padding: 16px; background: var(--bg); border: 2px solid var(--border); border-radius: var(--radius); font-size: 16px; font-weight: 800; color: var(--text); cursor: pointer; font-family: 'Nunito', sans-serif; }
.btn-replay { padding: 16px; background: var(--orange); border: none; border-radius: var(--radius); font-size: 16px; font-weight: 800; color: white; cursor: pointer; font-family: 'Nunito', sans-serif; box-shadow: 0 4px 16px rgba(255,107,53,.35); }

/* ---- STAT DOTS ---- */
.stat-row { display: flex; justify-content: center; gap: 6px; margin-bottom: 16px; flex-wrap: wrap; }
.stat-dot { width: 10px; height: 10px; border-radius: 50%; }
.stat-dot.ok { background: var(--green); }
.stat-dot.ko { background: var(--red); }
.stat-dot.pending { background: var(--border); }
</style>
</head>
<body>

<header class="app-header">
  <div class="app-logo">🧹</div>
  <div class="app-header-text">
    <div class="app-header-title">Les corvées</div>
    <div class="app-header-sub" id="header-sub">Négation en néerlandais</div>
  </div>
  <div class="score-chip" id="score-chip">0 pt</div>
</header>

<div class="progress-wrap" id="progress-wrap">
  <div class="progress-track"><div class="progress-fill" id="progress-fill" style="width:0%"></div></div>
  <div class="progress-label">
    <span id="prog-label-left">Question 1/15</span>
    <span id="prog-label-right">0%</span>
  </div>
</div>

<div class="scroll-body">

  <!-- MENU -->
  <div class="view active" id="view-menu">
    <div class="menu-hero">
      <div class="menu-emoji">🧹</div>
      <div class="menu-title">De corvees</div>
      <div class="menu-desc">Entraîne-toi à la négation en néerlandais<br>geen · niet · al · nog niet · nog geen</div>
    </div>
    <div class="badge-unlocked" id="badge-unlocked">Niveau difficile débloqué !</div>
    <div class="lock-msg" id="lock-msg">Réussis le niveau facile (7/15 minimum) pour débloquer le niveau difficile.</div>
    <div class="section-label">Choisis ton niveau</div>
    <div class="level-grid">
      <div class="level-card selected" id="lcard-easy" onclick="selectLevel('easy')">
        <div class="level-card-icon">⭐</div>
        <div class="level-card-name">Facile</div>
        <div class="level-card-desc">Règles de base</div>
      </div>
      <div class="level-card locked" id="lcard-hard" onclick="selectLevel('hard')">
        <div class="level-card-icon">⭐⭐</div>
        <div class="level-card-name">Difficile</div>
        <div class="level-card-desc">Cas complexes</div>
        <div class="lock-overlay" id="lock-icon">🔒</div>
      </div>
    </div>
    <button class="btn-start" onclick="startGame()">Commencer →</button>
  </div>

  <!-- GAME -->
  <div class="view" id="view-game">
    <div class="q-card" id="q-card">
      <div class="q-mode-badge" id="q-mode-badge">QCM</div>
      <div class="q-sentence" id="q-sentence"></div>
      <div class="q-hint" id="q-hint"></div>
      <div class="q-fr" id="q-fr"></div>
    </div>

    <div id="zone-qcm" style="display:none">
      <div class="choices" id="qcm-choices"></div>
    </div>

    <div id="zone-build" style="display:none">
      <div class="build-zone">
        <div class="zone-label">Ta phrase :</div>
        <div class="built-area" id="built-area"></div>
        <div class="zone-label">Mots disponibles :</div>
        <div class="word-bank" id="word-bank"></div>
        <div class="build-controls">
          <button class="btn-clear" onclick="buildClear()">Effacer</button>
          <button class="btn-verify" onclick="buildCheck()">Vérifier ✓</button>
        </div>
      </div>
    </div>

    <div id="zone-write" style="display:none">
      <div class="write-zone">
        <div class="zone-label">Écris la phrase complète :</div>
        <textarea class="write-textarea" id="write-input" placeholder="Ta réponse en néerlandais…" rows="2" oninput="autoResize(this)"></textarea>
        <div style="margin-top:10px">
          <button class="btn-verify" style="width:100%" onclick="writeCheck()">Vérifier ✓</button>
        </div>
      </div>
    </div>

    <div class="feedback" id="g-feedback"></div>
    <div style="height:80px"></div>
  </div>

  <!-- END -->
  <div class="view" id="view-end">
    <div class="end-card">
      <div class="end-trophy" id="end-trophy"></div>
      <div class="end-title" id="end-title"></div>
      <div class="stat-row" id="stat-row"></div>
      <div class="end-score" id="end-score"></div>
      <div class="end-msg" id="end-msg"></div>
      <div class="end-unlock-msg" id="end-unlock-msg">🎉 Niveau difficile débloqué !</div>
    </div>
    <div class="end-btns">
      <button class="btn-replay" onclick="restartSame()">Rejouer ce niveau</button>
      <button class="btn-menu" onclick="goMenu()">Retour au menu</button>
    </div>
  </div>

</div>

<!-- STICKY NEXT -->
<div class="sticky-next" id="sticky-next">
  <button class="btn-next" id="btn-next" onclick="nextQ()">Question suivante →</button>
</div>

<script>
let curLevel='easy',lastLevel='easy',easyPassed=false;
let questions=[],qIdx=0,score=0,answered=false,builtWords=[];
let results=[];

const easyData=[
  {type:'qcm',sentence:'Ik doe ____ corvees vandaag.',fr:'Je ne fais pas de corvées aujourd\'hui.',hint:'corvees = pluriel indéfini',choices:['geen','niet','nee'],answer:'geen',expl:'<strong>Geen</strong> devant un nom indéfini pluriel : <em>Ik doe geen corvees vandaag.</em>'},
  {type:'qcm',sentence:'Ik koop het brood ____.',fr:'Je n\'achète pas le pain.',hint:'het brood = défini',choices:['geen','niet','nog niet'],answer:'niet',expl:'<strong>Niet</strong> car het brood est défini (het) : <em>Ik koop het brood niet.</em>'},
  {type:'qcm',sentence:'Heb je de tafel al gedekt? — Nee, ____.',fr:'Tu as déjà mis la table ? — Non, pas encore.',hint:'pas encore fait',choices:['nog niet','nog geen','niet'],answer:'nog niet',expl:'<strong>Nog niet</strong> = pas encore. On nie l\'action : <em>Nee, nog niet.</em>'},
  {type:'qcm',sentence:'Heb je ____ afgewassen?',fr:'Tu as déjà fait la vaisselle ?',hint:'déjà accompli ?',choices:['al','nog','niet'],answer:'al',expl:'<strong>Al</strong> = déjà : <em>Heb je al afgewassen?</em>'},
  {type:'qcm',sentence:'Heb je al een stofzuiger? — Nee, ik heb ____.',fr:'Tu as déjà un aspirateur ? — Non, pas encore.',hint:'pas encore + objet indéfini',choices:['nog geen','nog niet','geen'],answer:'nog geen',expl:'<strong>Nog geen</strong> devant un nom indéfini : <em>Ik heb nog geen stofzuiger.</em>'},
  {type:'qcm',sentence:'Ik geef de bloemen ____ water.',fr:'Je n\'arrose pas les fleurs.',hint:'water = substance indéfinie',choices:['geen','niet','nog niet'],answer:'geen',expl:'<strong>Geen water</strong> = substance non comptable : <em>Ik geef de bloemen geen water.</em>'},
  {type:'qcm',sentence:'Is het bed ____ opgemaakt?',fr:'Le lit est-il déjà fait ?',hint:'déjà fait ?',choices:['al','nog niet','niet'],answer:'al',expl:'<strong>Al</strong> = déjà : <em>Is het bed al opgemaakt?</em>'},
  {type:'build',fr:'Je ne fais pas les courses.',hint:'boodschappen doen',words:['Ik','doe','geen','boodschappen','.'],answer:['Ik','doe','geen','boodschappen','.'],expl:'<strong>Geen boodschappen</strong> : nom indéfini. <em>Ik doe geen boodschappen.</em>'},
  {type:'build',fr:'Il ne range pas la chambre.',hint:'de kamer opruimen — verbe séparable',words:['Hij','ruimt','de','kamer','niet','op','.'],answer:['Hij','ruimt','de','kamer','niet','op','.'],expl:'<strong>Niet</strong> avant la particule op : <em>Hij ruimt de kamer niet op.</em>'},
  {type:'build',fr:'Je n\'ai pas encore fait le lit.',hint:'het bed opmaken',words:['Ik','heb','het','bed','nog niet','opgemaakt','.'],answer:['Ik','heb','het','bed','nog niet','opgemaakt','.'],expl:'<strong>Nog niet</strong> avant le participe : <em>Ik heb het bed nog niet opgemaakt.</em>'},
  {type:'build',fr:'Nous n\'arrosons pas les fleurs.',hint:'bloemen water geven',words:['We','geven','de','bloemen','geen','water','.'],answer:['We','geven','de','bloemen','geen','water','.'],expl:'<strong>Geen water</strong> : <em>We geven de bloemen geen water.</em>'},
  {type:'write',fr:'Je n\'ai pas encore de lave-vaisselle.',hint:'vaatwasser',answer:'Ik heb nog geen vaatwasser.',alts:['ik heb nog geen vaatwasser'],expl:'<strong>Nog geen + nom indéfini</strong> : <em>Ik heb nog geen vaatwasser.</em>'},
  {type:'write',fr:'Il n\'achète pas de pain.',hint:'brood kopen',answer:'Hij koopt geen brood.',alts:['hij koopt geen brood'],expl:'<strong>Geen brood</strong> (indéfini) : <em>Hij koopt geen brood.</em>'},
  {type:'write',fr:'Elle n\'a pas encore sorti le chien.',hint:'de hond uitlaten',answer:'Ze heeft de hond nog niet uitgelaten.',alts:['ze heeft de hond nog niet uitgelaten'],expl:'<strong>Nog niet</strong> avant le participe : <em>Ze heeft de hond nog niet uitgelaten.</em>'},
  {type:'write',fr:'Il ne tond pas le gazon.',hint:'het gras maaien',answer:'Hij maait het gras niet.',alts:['hij maait het gras niet'],expl:'<strong>Niet</strong> en fin de phrase : <em>Hij maait het gras niet.</em>'},
];

const hardData=[
  {type:'qcm',sentence:'Ze maakt de kooi van de cavia ____ schoon.',fr:'Elle ne nettoie pas la cage du cochon d\'Inde.',hint:'schoonmaken — particule séparable',choices:['niet (avant schoon)','niet (fin)','geen'],answer:'niet (avant schoon)',expl:'<strong>Niet</strong> juste avant la particule séparable : <em>Ze maakt de kooi niet schoon.</em>'},
  {type:'qcm',sentence:'Heb je al een auto? — Nee, ik heb ____ auto.',fr:'Tu as déjà une voiture ? — Non, pas encore.',hint:'auto = indéfini',choices:['nog geen','nog niet','geen al'],answer:'nog geen',expl:'<strong>Nog geen + nom</strong> : <em>Ik heb nog geen auto.</em>'},
  {type:'qcm',sentence:'Ze gaat ____ naar de winkel.',fr:'Elle ne va pas au magasin.',hint:'nier le complément de direction',choices:['niet (avant naar)','niet (fin)','geen'],answer:'niet (avant naar)',expl:'<strong>Niet</strong> avant le complément de direction : <em>Ze gaat niet naar de winkel.</em>'},
  {type:'qcm',sentence:'Het gras is ____ kort genoeg.',fr:'La pelouse n\'est pas assez courte.',hint:'nier l\'adjectif attribut',choices:['niet (avant kort)','niet (fin)','geen'],answer:'niet (avant kort)',expl:'<strong>Niet</strong> avant l\'adjectif attribut : <em>Het gras is niet kort genoeg.</em>'},
  {type:'qcm',sentence:'Dit is ____ mijn taak.',fr:'Ce n\'est pas ma tâche.',hint:'nier le pronom possessif',choices:['niet','geen','nog niet'],answer:'niet',expl:'<strong>Niet</strong> devant un pronom possessif (mijn). Geen ne s\'utilise jamais devant un pronom : <em>Dit is niet mijn taak.</em>'},
  {type:'qcm',sentence:'Is de garage al opgeruimd? — Nee, ____.',fr:'Le garage est-il déjà rangé ? — Non, pas encore.',hint:'état pas encore atteint',choices:['nog niet','nog geen','niet al'],answer:'nog niet',expl:'<strong>Nog niet</strong> pour nier un état : <em>Nee, nog niet.</em>'},
  {type:'qcm',sentence:'Heeft hij al een grasmaaier? — Nee, hij heeft ____.',fr:'Il a déjà une tondeuse ? — Non, pas encore.',hint:'grasmaaier = indéfini',choices:['nog geen grasmaaier','nog niet','geen grasmaaier'],answer:'nog geen grasmaaier',expl:'<strong>Nog geen + nom</strong> : <em>Hij heeft nog geen grasmaaier.</em>'},
  {type:'build',fr:'Il ne nettoie pas la cage du cochon d\'Inde.',hint:'schoonmaken — verbe séparable',words:['Hij','maakt','de','kooi','van','de','cavia','niet','schoon','.'],answer:['Hij','maakt','de','kooi','van','de','cavia','niet','schoon','.'],expl:'<strong>Niet</strong> avant schoon : <em>Hij maakt de kooi van de cavia niet schoon.</em>'},
  {type:'build',fr:'Je ne veux pas sortir les sacs poubelles.',hint:'buitenzetten — nier l\'infinitif',words:['Ik','wil','de','vuilniszakken','niet','buitenzetten','.'],answer:['Ik','wil','de','vuilniszakken','niet','buitenzetten','.'],expl:'<strong>Niet</strong> avant l\'infinitif séparable : <em>Ik wil de vuilniszakken niet buitenzetten.</em>'},
  {type:'build',fr:'Elle n\'a pas encore de tondeuse.',hint:'grasmaaier — nog geen',words:['Ze','heeft','nog','geen','grasmaaier','.'],answer:['Ze','heeft','nog','geen','grasmaaier','.'],expl:'<strong>Nog geen + nom</strong> : <em>Ze heeft nog geen grasmaaier.</em>'},
  {type:'build',fr:'Il ne va pas travailler dans le jardin.',hint:'in de tuin werken',words:['Hij','gaat','niet','in','de','tuin','werken','.'],answer:['Hij','gaat','niet','in','de','tuin','werken','.'],expl:'<strong>Niet</strong> avant le lieu : <em>Hij gaat niet in de tuin werken.</em>'},
  {type:'write',fr:'Elle ne fait pas la vaisselle.',hint:'afwassen — verbe séparable',answer:'Ze wast niet af.',alts:['ze wast niet af'],expl:'<strong>Niet</strong> avant la particule af : <em>Ze wast niet af.</em>'},
  {type:'write',fr:'Ils ne cirent pas de chaussures le lundi.',hint:'schoenen poetsen',answer:'Ze poetsen geen schoenen op maandag.',alts:['ze poetsen geen schoenen op maandag'],expl:'<strong>Geen</strong> devant nom pluriel indéfini : <em>Ze poetsen geen schoenen op maandag.</em>'},
  {type:'write',fr:'Tu n\'as pas encore passé l\'aspirateur.',hint:'stofzuigen',answer:'Je hebt nog niet gestofzuigd.',alts:['je hebt nog niet gestofzuigd'],expl:'<strong>Nog niet</strong> avant le participe : <em>Je hebt nog niet gestofzuigd.</em>'},
  {type:'write',fr:'Je n\'ai pas encore de petit frère ou sœur à garder.',hint:'op de kleine broer/zus passen',answer:'Ik heb nog geen kleine broer of zus.',alts:['ik heb nog geen kleine broer of zus'],expl:'<strong>Nog geen + nom</strong> : <em>Ik heb nog geen kleine broer of zus.</em>'},
];

const modeLabel={qcm:'QCM',build:'Remettre en ordre',write:'À écrire'};
const letters=['A','B','C','D'];

function shuffle(a){let r=[...a];for(let i=r.length-1;i>0;i--){let j=Math.floor(Math.random()*(i+1));[r[i],r[j]]=[r[j],r[i]];}return r;}

function showView(id){
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.getElementById('view-'+id).classList.add('active');
  window.scrollTo(0,0);
}

function selectLevel(l){
  if(l==='hard'&&!easyPassed){document.getElementById('lock-msg').classList.add('show');return;}
  document.getElementById('lock-msg').classList.remove('show');
  curLevel=l;
  document.getElementById('lcard-easy').classList.toggle('selected',l==='easy');
  document.getElementById('lcard-hard').classList.toggle('selected',l==='hard');
}

function startGame(){
  lastLevel=curLevel;
  questions=shuffle(curLevel==='easy'?[...easyData]:[...hardData]);
  qIdx=0;score=0;answered=false;results=[];
  document.getElementById('score-chip').classList.add('show');
  document.getElementById('progress-wrap').classList.add('show');
  document.getElementById('header-sub').textContent=curLevel==='easy'?'Niveau facile':'Niveau difficile';
  showView('game');
  loadQ();
}

function updateHeader(){
  document.getElementById('score-chip').textContent=score+' pt';
  const pct=Math.round(qIdx/questions.length*100);
  document.getElementById('progress-fill').style.width=pct+'%';
  document.getElementById('prog-label-left').textContent='Question '+(qIdx+1)+'/'+questions.length;
  document.getElementById('prog-label-right').textContent=pct+'%';
}

function loadQ(){
  const q=questions[qIdx];answered=false;builtWords=[];
  updateHeader();
  document.getElementById('q-mode-badge').textContent=modeLabel[q.type];
  document.getElementById('q-hint').textContent=q.hint?'('+q.hint+')':'';
  document.getElementById('q-fr').textContent=q.fr?'→ '+q.fr:'';
  document.getElementById('g-feedback').className='feedback';
  document.getElementById('sticky-next').className='sticky-next';
  ['zone-qcm','zone-build','zone-write'].forEach(z=>document.getElementById(z).style.display='none');

  if(q.type==='qcm'){
    const parts=q.sentence.split('____');
    document.getElementById('q-sentence').innerHTML=parts.length===2?parts[0]+'<span class="blank">____</span>'+parts[1]:q.sentence;
    document.getElementById('zone-qcm').style.display='block';
    const cg=document.getElementById('qcm-choices');cg.innerHTML='';
    shuffle(q.choices).forEach((c,i)=>{
      const b=document.createElement('button');b.className='choice-btn';
      b.innerHTML='<span class="choice-letter">'+letters[i]+'</span><span>'+c+'</span>';
      b.onclick=()=>qcmChoose(c,q,b);cg.appendChild(b);
    });
  } else if(q.type==='build'){
    document.getElementById('q-sentence').innerHTML='';
    document.getElementById('zone-build').style.display='block';
    renderBuilt();renderBank(q);
  } else {
    document.getElementById('q-sentence').innerHTML='';
    const inp=document.getElementById('write-input');
    inp.value='';inp.className='write-textarea';inp.disabled=false;inp.style.height='auto';
    document.getElementById('zone-write').style.display='block';
    setTimeout(()=>inp.focus(),100);
  }
}

function qcmChoose(val,q,clicked){
  if(answered)return;answered=true;
  const ok=val===q.answer;
  document.querySelectorAll('.choice-btn').forEach(b=>{
    b.disabled=true;
    const txt=b.querySelector('span:last-child').textContent;
    if(txt===q.answer)b.classList.add(ok&&b===clicked?'correct':'missed');
    else if(b===clicked&&!ok)b.classList.add('wrong');
  });
  showFb(ok,q.answer,q.expl);
}

function renderBuilt(){
  const el=document.getElementById('built-area');
  if(!builtWords.length){el.innerHTML='<span style="color:#B0B0C0;font-weight:600;font-size:14px">Clique sur les mots ci-dessous…</span>';return;}
  el.innerHTML=builtWords.map((w,i)=>'<span class="wchip" onclick="removeWord('+i+')">'+w+' ✕</span>').join(' ');
}
function renderBank(q){
  const el=document.getElementById('word-bank');el.innerHTML='';
  shuffle(q.words).forEach(w=>{
    const b=document.createElement('button');b.className='wb-btn';b.dataset.w=w;b.textContent=w;
    b.onclick=()=>addWord(w,b);el.appendChild(b);
  });
}
function addWord(w,btn){if(btn.classList.contains('used'))return;btn.classList.add('used');builtWords.push(w);renderBuilt();}
function removeWord(i){const w=builtWords[i];builtWords.splice(i,1);renderBuilt();const all=document.querySelectorAll('#word-bank .wb-btn');for(let b of all){if(b.dataset.w===w&&b.classList.contains('used')){b.classList.remove('used');break;}}}
function buildClear(){builtWords=[];document.querySelectorAll('#word-bank .wb-btn').forEach(b=>b.classList.remove('used'));renderBuilt();}
function buildCheck(){
  const q=questions[qIdx];if(!builtWords.length||answered)return;answered=true;
  document.querySelectorAll('#word-bank .wb-btn').forEach(c=>c.disabled=true);
  const ok=builtWords.join(' ').trim().toLowerCase()===q.answer.join(' ').trim().toLowerCase();
  showFb(ok,q.answer.join(' '),q.expl);
}
function writeCheck(){
  const q=questions[qIdx];const inp=document.getElementById('write-input');
  const val=inp.value.trim();if(!val||answered)return;answered=true;inp.disabled=true;
  const norm=s=>s.toLowerCase().replace(/[.!?]/g,'').trim();
  const ok=norm(val)===norm(q.answer)||(q.alts&&q.alts.some(a=>norm(val)===norm(a)));
  inp.className='write-textarea '+(ok?'ok':'ko');
  showFb(ok,q.answer,q.expl);
}
function showFb(ok,correctAns,expl){
  if(ok)score++;
  results.push(ok);
  updateHeader();
  const fb=document.getElementById('g-feedback');
  fb.className='feedback '+(ok?'ok':'ko')+' show';
  fb.innerHTML=(ok?'<div class="fb-icon">✅</div>':'<div class="fb-icon">❌</div>')+(ok?'Bien joué ! ':'Réponse correcte : <strong>'+correctAns+'</strong><br>')+expl;
  const isLast=qIdx===questions.length-1;
  document.getElementById('btn-next').textContent=isLast?'Voir mes résultats →':'Question suivante →';
  document.getElementById('sticky-next').className='sticky-next show';
  setTimeout(()=>window.scrollTo({top:document.body.scrollHeight,behavior:'smooth'}),100);
}
function nextQ(){qIdx++;if(qIdx>=questions.length)showEnd();else loadQ();}

function showEnd(){
  document.getElementById('score-chip').classList.remove('show');
  document.getElementById('progress-wrap').classList.remove('show');
  showView('end');
  const tot=questions.length,pct=score/tot;
  const statRow=document.getElementById('stat-row');
  statRow.innerHTML=results.map(r=>'<div class="stat-dot '+(r?'ok':'ko')+'"></div>').join('');
  document.getElementById('end-score').textContent=score+'/'+tot;
  let trophy,title,msg;
  if(pct>=0.9){trophy='🏆';title='Maître des corvées !';msg='Tu maîtrises parfaitement la négation en néerlandais. Incroyable !';}
  else if(pct>=0.7){trophy='🥇';title='Excellent travail !';msg='Tu es sur la bonne voie. Encore quelques points à consolider !';}
  else if(pct>=0.5){trophy='🥈';title='Bien essayé !';msg='La négation néerlandaise s\'entraîne. Rejoue pour progresser !';}
  else{trophy='💪';title='Continue d\'essayer !';msg='Relis les règles et réessaie — tu vas y arriver !';}
  document.getElementById('end-trophy').textContent=trophy;
  document.getElementById('end-title').textContent=title;
  document.getElementById('end-msg').textContent=msg;
  const wasLocked=!easyPassed;
  if(lastLevel==='easy'&&pct>=7/15){
    easyPassed=true;
    document.getElementById('lcard-hard').classList.remove('locked');
    document.getElementById('lock-icon').style.display='none';
    document.getElementById('badge-unlocked').classList.add('show');
    if(wasLocked)document.getElementById('end-unlock-msg').classList.add('show');
  }
}
function goMenu(){
  document.getElementById('score-chip').classList.remove('show');
  document.getElementById('progress-wrap').classList.remove('show');
  document.getElementById('header-sub').textContent='Négation en néerlandais';
  showView('menu');
}
function restartSame(){curLevel=lastLevel;startGame();}
function autoResize(el){el.style.height='auto';el.style.height=(el.scrollHeight)+'px';}
</script>
